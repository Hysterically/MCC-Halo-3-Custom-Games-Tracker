# H3 customs watcher config. Copy this file to watcher.env (same folder as
# watcher.mjs) and fill in the webhook line your host gave you.

# REQUIRED — the group's #carnage-inbox upload URL. Write-only: it can post
# files into that one channel and nothing else.
WEBHOOK_URL=https://discord.com/api/webhooks/CHANGE/ME

# Optional — only needed if MCC writes its reports somewhere non-standard.
# Default: C:\Users\<you>\AppData\LocalLow\MCC\Temporary
#MCC_CARNAGE_DIR=

# Copy to .env and fill in. Every line is optional — defaults work on the
# gaming PC with no config at all (Discord is just disabled).

# Folder MCC writes mpcarnagereport*.xml to. Default:
#   %USERPROFILE%\AppData\LocalLow\MCC\Temporary
# MCC_CARNAGE_DIR=C:\Users\you\AppData\LocalLow\MCC\Temporary

# SQLite database file. Default: ./data/h3.db
# DB_PATH=./data/h3.db

# ELO tuning. Defaults: start 1200, K 32.
# ELO_START=1200
# ELO_K=32

# --- Discord ---------------------------------------------------------------
# Two webhooks, one per channel, used for different purposes:
#
#  - DISCORD_RESULTS_WEBHOOK_URL: posts a per-match summary (gametype,
#    teams, K/D/A, winner) every time a new match is recorded.
#    Point this at e.g. #game-results.
#
#  - DISCORD_LEADERBOARD_WEBHOOK_URL: maintains a single, always-current
#    leaderboard message edited in place after each match. No notification
#    spam, no scrolling. Point this at e.g. #leaderboard.
#
# Channel settings → Integrations → Webhooks → New Webhook → Copy URL.
# DISCORD_RESULTS_WEBHOOK_URL=
# DISCORD_LEADERBOARD_WEBHOOK_URL=

# Discord bot token — enables /leaderboard and /stats slash commands.
# https://discord.com/developers/applications → your app → Bot → Reset Token.
# DISCORD_BOT_TOKEN=

# Server (guild) ID to register slash commands in. Optional but recommended:
# guild commands appear instantly; global ones take ~1 hour.
# DISCORD_GUILD_ID=

{
  "name": "h3-customs-tracker",
  "version": "0.0.1",
  "private": true,
  "description": "Tracks Halo 3 (MCC) custom games from local mpcarnagereport*.xml and posts an ELO leaderboard to Discord.",
  "type": "module",
  "scripts": {
    "inspect": "tsx src/inspect.ts",
    "parse": "tsx src/parse.ts",
    "watch": "tsx src/watch.ts",
    "backfill": "tsx src/backfill.ts",
    "board": "tsx src/board.ts",
    "announce": "tsx src/announce.ts",
    "clear": "tsx src/clear.ts",
    "remove-match": "tsx src/removeMatch.ts",
    "add-missed-games": "tsx src/addMissedGames.ts",
    "exclude-match": "tsx src/excludeMatch.ts",
    "hide-player": "tsx src/hidePlayer.ts",
    "testpost": "tsx src/testPost.ts",
    "restyle": "tsx src/restyleResults.ts",
    "setup": "tsx src/setup.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@napi-rs/canvas": "^1.0.0",
    "chokidar": "^4.0.3",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

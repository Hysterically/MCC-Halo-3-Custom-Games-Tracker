// Windows VERSIONINFO resource — configured by CMake (see CMakeLists.txt).
// Unsigned exes with no version metadata score badly with Defender's ML
// heuristics; this block (plus the manifest) makes the exe identify itself.

#include <windows.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @H3_VER_MAJOR@,@H3_VER_MINOR@,@H3_VER_PATCH@,0
 PRODUCTVERSION @H3_VER_MAJOR@,@H3_VER_MINOR@,@H3_VER_PATCH@,0
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
 FILEFLAGS 0x0L
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Hysterically"
            VALUE "FileDescription", "Halo 3 (MCC) Custom Games Tracker"
            VALUE "FileVersion", "@H3_VER_DISPLAY@"
            VALUE "InternalName", "h3-tracker"
            VALUE "LegalCopyright", "Copyright (c) 2026 Hysterically"
            VALUE "OriginalFilename", "h3-tracker.exe"
            VALUE "ProductName", "MCC Halo 3 Custom Games Tracker"
            VALUE "ProductVersion", "@H3_VER_DISPLAY@"
            VALUE "Comments", "https://github.com/Hysterically/MCC-Halo-3-Custom-Games-Tracker"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
